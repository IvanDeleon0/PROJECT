// Function to save all user accounts to file
void saveToFile(const vector<Account> &userAccount){
    ofstream outfile("Accounts Database.txt");
    
    if(!outfile){
        cout << red <<"Error: Could not create the saved file" << reset <<endl;
    }
    
    for(const auto& acc: userAccount){
        outfile << acc.username << endl;
        outfile << acc.pin << endl;

        //storing the size of the vectors first so that we can load it properly in 'loadToFile' function
        outfile << acc.content.anime_names.size() << endl;
        for(size_t i = 0; i < acc.content.anime_names.size(); ++i){
            outfile << acc.content.anime_names[i] << endl;
            outfile << acc.content.anime_eps[i] << endl;
        }
        outfile << acc.content.manga_names.size() << endl;
        for(size_t i = 0; i < acc.content.manga_names.size(); ++i){
            outfile << acc.content.manga_names[i] << endl;
            outfile << acc.content.manga_chpts[i] << endl;
        }
    }
    outfile.close();
}
// Function to load user accounts from file
void loadToFile(vector<Account>&userAccount){
    ifstream infile("Accounts Database.txt");
    
    if(!infile) return;  // If file doesn't exist, return (no accounts to load)
    
    Account temp;  // Temporary account to read data into
    
    // Read accounts until end of file
    while(infile >> temp.username >> temp.pin){  // Read username and pin
        cout << "Loading account: " << temp.username << endl;  // Debug output
        size_t anime_count;
        infile >> anime_count;  // Read number of anime entries

        if(anime_count > 10000) 
        { cout << "Invalid anime count: " << anime_count << endl; break; }  // Safety check

        temp.content.anime_names.resize(anime_count);  // Resize vectors to fit
        temp.content.anime_eps.resize(anime_count);
        
        // Read each anime name and episodes
        for(size_t i = 0; i < anime_count; ++i){
            infile >> temp.content.anime_names[i] >> temp.content.anime_eps[i];
        }
        size_t manga_count;
        infile >> manga_count;  // Read number of manga entries
        if(manga_count > 10000) { cout << "Invalid manga count: " << manga_count << endl; break; }  // Safety check
        temp.content.manga_names.resize(manga_count);
        temp.content.manga_chpts.resize(manga_count);
        
        // Read each manga name and chapters
        for(size_t i = 0; i < manga_count; ++i){
            infile >> temp.content.manga_names[i] >> temp.content.manga_chpts[i];
        }
        userAccount.push_back(temp);  // Add loaded account to the vector
    }
}

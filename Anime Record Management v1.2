void saveToFile(const vector<Account> &userAccount){
    ofstream outfile("Accounts Database.txt");
    
    if(!outfile){
        cout << red <<"Error: Could not create the saved file" << reset <<endl;
    }
    
    for(const auto& acc: userAccount){
        outfile << acc.username << " " 
                << acc.pin << " " 
                << acc.content.totalSeeAnime << " "
                << acc.content.manga_name << " "
                << acc.content.manga_chpt << " "
                << acc.content.totalReadManga << endl;
    }
    outfile.close();
}
void loadToFile(vector<Account>&userAccount){
    ifstream infile("Accounts Database.txt");
    
    if(!infile) return; //meaning no file with such name is created or found
    
    Account temp; /*this time instead of merging all content to save the accounts, now its to load the accounts, CONTAINER OF DATA*/
    
    while(infile >> temp.username 
                 >> temp.pin 
                 >> temp.content.totalSeeAnime 
                 >> temp.content.manga_name 
                 >> temp.content.manga_chpt 
                 >> temp.content.totalReadManga)
                 { userAccount.push_back(temp);
    }
}
